# Vercel + Supabase integration (auto-synced by Vercel Marketplace)
# https://vercel.com/marketplace/supabase
#
# Production already receives:
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
#   NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY
#   POSTGRES_URL, POSTGRES_URL_NON_POOLING, etc.
#
# Vite reads these at build time via vite.config.ts (no VITE_ prefix required).
#
# Optional overrides:
# APP_URL=https://thehub-6426.vercel.app
# VITE_APP_URL=https://thehub-6426.vercel.app
#
# Apply database schema (after vercel env pull):
#   npx vercel env pull .env.vercel.production --environment=production
#   npm run db:apply
